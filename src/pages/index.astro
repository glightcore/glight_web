
---
const modulesLeft = [
  "GLightOne",
  "OrbitOne",
  "Hexagon",
  "N-LAB",
  "Reserved"
  
];

const modulesRight = [
  "Evo prime",
  "GLight Graphics",
  "Reactor",
  "Sentinel",
  "Pulse" // ← tu nuevo nodo
];

---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GLight</title>

<!-- CSS PRINCIPAL -->
<link rel="stylesheet" href="/glight.css" />

<!-- PRELOAD DE MÓDULOS -->
<link rel="preload" as="image" href="/modules/glightone.webp">
<link rel="preload" as="image" href="/modules/orbitone.webp">
<link rel="preload" as="image" href="/modules/hexagon.webp">
<link rel="preload" as="image" href="/modules/nlab.webp">
<link rel="preload" as="image" href="/modules/evoprime.webp">
<link rel="preload" as="image" href="/modules/glightgraphics.webp">
<link rel="preload" as="image" href="/modules/reactor.webp">
<link rel="preload" as="image" href="/modules/sentinel.webp">
</head>

<body class="page">

  <!-- PLANO FÍSICO -->
<main class="stage">

  <div class="reactor-wrapper">

    <div class="reactor">

      <div class="core"></div>
      <div class="reactor-flash"></div>

      <div id="moduleName" class="module-name"></div>

      <!-- PORTAL -->
      <div class="portal">

        <div class="tech-spec">

         <h3>GLIGHT / GLIGHTCOREAURA TECHNOLOGY PLATFORM</h3>

<p>
Integrated hardware, firmware and intelligent systems ecosystem
for power electronics, advanced illumination architectures,
automotive calibration platforms and electronic control technologies.
</p>

<p class="tech-note">
Modular architectures, intelligent control layers
and protected technological frameworks.
</p>

<p class="tech-origin">
Tokyo — Japan
</p>

        </div>

      </div>

    </div>

    <!-- MODULE VIEW -->
    <div class="module-view">
      <img id="moduleImage" src="" alt="module">
    </div>

  </div>

</main>

  <!-- PLANO HUD / INTERFAZ -->
  <div class="hud">

    <!-- TÍTULO -->
    <div class="brand-title">
        <img src="/GLIGHTCOREAURA_ORBITRON1.svg" alt="GLightCoreAura" class="brand-logo"/>
    </div>

    <!-- NODOS -->
    <div class="nodes left">
        {modulesLeft.map(name => (
            <div class="node" data-name={name}></div>
        ))}
    </div>

    <div class="nodes right">
        {modulesRight.map(name => (
            <div class="node" data-name={name}></div>
        ))}
    </div>

    <!-- 🔥 SYSTEM SIGNATURE -->
    <div class="system-tag">SYSTEM LAYER CORE</div>

</div>

  </div>

</body>

<!-- ===== SCRIPT DE ACTIVACIÓN ===== -->

<script>




/* =================================================
   REFERENCIAS DOM
================================================= */

const nodes = document.querySelectorAll('.node');
const moduleName = document.getElementById('moduleName');
const page = document.querySelector('.page');
const flash = document.querySelector('.reactor-flash');
const reactor = document.querySelector('.reactor');
const core = document.querySelector('.core');
const portal = document.querySelector(".portal");
const brandTitle = document.querySelector('.brand-title');

const moduleView = document.querySelector('.module-view');
const moduleImage = document.getElementById('moduleImage');
const techSpec = document.querySelector('.tech-spec');
const originalTechSpec = techSpec.innerHTML;
/* ================================================
   ESTADO GLOBAL
================================================ */

let portalActivated = false;
let selectedModule = null;

/* estado inicial del reactor */
moduleName.textContent = "GLIGHT";
page.classList.add('idle-mode');


/* ================================================
   PORTAL
================================================ */

function activatePortal() {

  reactor.classList.remove('portal-open');

  /* fuerza reflow para reiniciar animación */
  void reactor.offsetWidth;

  reactor.classList.add('portal-open');
  reactorFlash();   // ⚡ DESTELLO DEL REACTOR

}

function reactorFlash(){

const flash = document.querySelector(".reactor-flash");

flash.style.animation = "none";
flash.offsetHeight;

flash.style.animation = "reactorFlash 0.7s cubic-bezier(.22,.61,.36,1) forwards";

}

/* ================================================
   IDLE SYSTEM (RETORNO AUTOMÁTICO)
================================================ */

let idleTimer = null;
const IDLE_TIME = 12000;   // 12 segundos


function returnToIdle(){

  portalActivated = false;
  selectedModule = null;

  portal.classList.remove('open');
  reactor.classList.remove('portal-open');

  nodes.forEach(node => node.classList.remove('active'));

  moduleImage.style.opacity = 0;

  moduleName.textContent = "GLIGHT";

  page.classList.remove('module-active');
  

}


function resetIdleTimer(){

  clearTimeout(idleTimer);

  idleTimer = setTimeout(() => {
    returnToIdle();
  }, IDLE_TIME);

}



/* =================================================
   INTERACCIÓN CORE REACTOR
================================================= */

if (reactor) {

  /* HOVER */

  reactor.addEventListener('mouseenter', () => {

    resetIdleTimer();

    if (portalActivated) return;
    
    reactor.classList.add('hover-active');
    core.classList.add('core-active');

  });


  reactor.addEventListener('mouseleave', () => {

    resetIdleTimer();

    if (portalActivated) return;

    reactor.classList.remove('hover-active');
    reactor.classList.remove('click-active');
    core.classList.remove('core-active');

  });


  /* PRESIÓN VISUAL */

  reactor.addEventListener('pointerdown', () => {

    resetIdleTimer();

    if (portalActivated) return;

    reactor.classList.add('click-active');
    core.classList.add('core-click');

  });


  reactor.addEventListener('pointerup', () => {

    resetIdleTimer();

    if (portalActivated) return;

    reactor.classList.remove('click-active');
    core.classList.remove('core-click');
    core.classList.remove('click-active');
  });

/* ACTIVAR PORTAL */
reactor.addEventListener('click', (e) => {

  // 🔥 FILTRO CLAVE
  if (e.target.closest('.tech-note')) return;

  resetIdleTimer();

  if (reactor.classList.contains('portal-open')) {

    moduleImage.style.opacity = "0";
    moduleImage.style.transform = "scale(.94)";

    setTimeout(() => {
      reactor.classList.remove('portal-open');
      portal.classList.remove('open');
      page.classList.remove('module-active');
      techSpec.style.opacity = "";
    }, 300);

  } else {

    reactor.classList.add('portal-open');
    portal.classList.add('open');

    reactorFlash();

    const currentModule = moduleName.textContent;

    if(currentModule === "GLIGHT") {
      page.classList.remove('module-active');
      techSpec.innerHTML = originalTechSpec;
      moduleImage.style.opacity = "0";
      moduleImage.style.transform = "scale(.9)";
    }

    else if(currentModule === "GLightOne") {
      page.classList.add('module-active');
      setTimeout(() => {
        moduleImage.src = "./glight-one-front-deep.png";
        moduleImage.style.opacity = "1";
        moduleImage.style.transform = "scale(1)";
      }, 300);
    }

    else if(currentModule === "Pulse") {
      page.classList.add('module-active');

      setTimeout(() => {

        moduleImage.style.opacity = "0";
        moduleImage.style.transform = "scale(.9)";

        techSpec.innerHTML = `
          <h3>PULSE / CONTACT NODE</h3>
        <p>Official technical access point for GLightCore.</p>
        <p class="tech-note">glight@glightcore.com</p>
        <p class="tech-origin">Tokyo — Japan</p>
        `;

        techSpec.style.opacity = "1";

      }, 300);
    }

    else {
      page.classList.add('module-active');
      setTimeout(() => {
        moduleImage.style.opacity = "0";
        moduleImage.style.transform = "scale(.9)";
      }, 100);
    }
  }
});
}


/* =================================================
   AUDIO ENGINE
================================================= */

let audioCtx = null;

function ensureAudio() {

  if (!audioCtx) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }

  if (audioCtx.state !== 'running') {
    audioCtx.resume();
  }

}


function playTone({

  freqStart,
  freqEnd = null,
  duration = 0.1,
  gain = 0.15,
  type = 'sine'

}) {

  ensureAudio();

  const osc = audioCtx.createOscillator();
  const g = audioCtx.createGain();

  osc.type = type;

  osc.frequency.setValueAtTime(freqStart, audioCtx.currentTime);

  if (freqEnd) {

    osc.frequency.exponentialRampToValueAtTime(
      freqEnd,
      audioCtx.currentTime + duration
    );

  }

  g.gain.setValueAtTime(0.0001, audioCtx.currentTime);

  g.gain.exponentialRampToValueAtTime(
    gain,
    audioCtx.currentTime + 0.01
  );

  g.gain.exponentialRampToValueAtTime(
    0.0001,
    audioCtx.currentTime + duration
  );

  osc.connect(g);
  g.connect(audioCtx.destination);

  osc.start();
  osc.stop(audioCtx.currentTime + duration + 0.02);

}


/* =================================================
   SONIDOS DE INTERACCIÓN
================================================= */

function soundHover() {

  playTone({
    freqStart: 2400,
    freqEnd: 1800,
    duration: 0.02,
    gain: 0.035,
    type: 'triangle'
  });

}


function soundClick() {

  ensureAudio();

  const now = audioCtx.currentTime;

  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();

  const delay = audioCtx.createDelay();
  const feedback = audioCtx.createGain();

  osc.type = 'triangle';

  osc.frequency.setValueAtTime(200, now);
  osc.frequency.exponentialRampToValueAtTime(120, now + 0.35);

  gain.gain.setValueAtTime(0.0001, now);
  gain.gain.exponentialRampToValueAtTime(0.10, now + 0.05);
  gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.45);

  delay.delayTime.value = 0.12;
  feedback.gain.value = 0.35;

  osc.connect(gain);
  gain.connect(audioCtx.destination);

  gain.connect(delay);
  delay.connect(feedback);
  feedback.connect(delay);
  delay.connect(audioCtx.destination);

  osc.start(now);
  osc.stop(now + 0.5);

}


/* =================================================
   CAMPO SONORO GLight
================================================= */

let fieldOsc = null;
let fieldGain = null;
let fieldInitialized = false;


window.addEventListener('pointerdown', () => {

  ensureAudio();
  initField();

}, { once: true });


function initField() {

  if (fieldInitialized) return;

  fieldOsc = audioCtx.createOscillator();
  fieldGain = audioCtx.createGain();

  fieldOsc.type = 'sine';

  fieldOsc.frequency.setValueAtTime(80, audioCtx.currentTime);
  fieldGain.gain.setValueAtTime(0.0001, audioCtx.currentTime);

  fieldOsc.connect(fieldGain);
  fieldGain.connect(audioCtx.destination);

  fieldOsc.start();

  fieldInitialized = true;

}


function enterField() {

  if (!fieldInitialized) return;

  const now = audioCtx.currentTime;

  fieldGain.gain.cancelScheduledValues(now);
  fieldOsc.frequency.cancelScheduledValues(now);

  fieldGain.gain.setValueAtTime(fieldGain.gain.value, now);
  fieldOsc.frequency.setValueAtTime(fieldOsc.frequency.value, now);

  fieldOsc.frequency.exponentialRampToValueAtTime(160, now + 0.18);
  fieldGain.gain.exponentialRampToValueAtTime(0.14, now + 0.18);

}


function leaveField() {

  if (!fieldInitialized) return;

  const now = audioCtx.currentTime;

  fieldGain.gain.cancelScheduledValues(now);
  fieldOsc.frequency.cancelScheduledValues(now);

  fieldGain.gain.setValueAtTime(fieldGain.gain.value, now);
  fieldOsc.frequency.setValueAtTime(fieldOsc.frequency.value, now);

  fieldOsc.frequency.exponentialRampToValueAtTime(70, now + 0.75);
  fieldGain.gain.exponentialRampToValueAtTime(0.0001, now + 0.9);

}


brandTitle.addEventListener('mouseenter', enterField);
brandTitle.addEventListener('mouseleave', leaveField);


/* =================================================
   INTERACCIÓN NODOS
================================================= */

nodes.forEach(node => {

  node.addEventListener('mouseenter', () => {

    soundHover();

  });

 node.addEventListener('click', () => {

soundClick();

techSpec.style.opacity = "0";

/* cerrar portal si estaba abierto */
if (reactor.classList.contains('portal-open')) {
    reactor.classList.remove('portal-open');
    portal.classList.remove('open');
    moduleImage.style.opacity = "0";
    moduleImage.style.transform = "scale(.9)";

}

nodes.forEach(n => n.classList.remove('active'));
node.classList.add('active');

moduleName.textContent = node.dataset.name;

page.classList.add('module-active');

flash.style.animation = 'none';
flash.offsetHeight;
flash.style.animation = '';

});

});

</script></body>
</html>